
<!DOCTYPE html>
<html lang="id" class="light">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - PU</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/webp" href="../assets/img/logo/favicon-pu.png">
    <!-- <link rel="stylesheet" href="../stylesheets/style.css"> -->

    
    <!-- Compiled Tailwind CSS -->
    <link rel="stylesheet" href="../stylesheets/output.css">
    
    
    <style>
        /* Search Input */
        .dataTables_wrapper .dataTables_filter input {
            @apply border border-gray-300 dark:border-dark-border rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-primary-500 dark:bg-slate-800 dark:text-gray-200;
        }

        /* Length Dropdown */
        .dataTables_wrapper .dataTables_length select {
            @apply border border-gray-300 dark:border-dark-border rounded-lg px-2 py-1 text-sm dark:bg-slate-800 dark:text-gray-200;
        }

        /* Pagination */
        .dataTables_wrapper .dataTables_paginate .paginate_button {
            @apply px-3 py-1 rounded-lg text-sm hover:bg-gray-100 dark:hover:bg-slate-700;
        }

        .dataTables_wrapper .dataTables_paginate .paginate_button.current {
            @apply bg-primary-500 text-white;
        }

        /* Remove weird border */
        table.dataTable.no-footer {
            border-bottom: none !important;
        }
    </style>

    <script src="https://unpkg.com/@phosphor-icons/web"></script>

    <style>
        /* Smooth transition for theme toggle */
        body {
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        .sidebar-transition {
            transition: transform 0.3s ease-in-out;
        }

        /* Hide scrollbar for standard look in sidebar */
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }

        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        
    </style>

    <style>
        @media print {
            /* Sembunyikan seluruh elemen di halaman */
            body * {
                visibility: hidden;
            }
            /* Tampilkan kembali hanya area invoice dan isi di dalamnya */
            #invoicePrintArea, #invoicePrintArea * {
                visibility: visible;
            }
            /* Atur posisi invoice agar berada di pojok kiri atas saat dicetak */
            #invoicePrintArea {
                position: absolute;
                left: 0;
                bottom: 10px;
                width: 100%;
                padding: 0;
                margin: 0;
            }
            /* Sembunyikan tombol cetak dan tutup saat proses print */
            .no-print {
                display: none !important;
            }

            .modal-invoice {
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                z-index: 50;
                overflow-x: hidden;
                overflow-y: auto;
                backdrop-filter: blur(8px);
                max-height: 100%;             
            }
            .modal-content-invoice {
                position: relative;
                background: white;
                border-radius: 16px;
                box-shadow: 0 25px 50px -12px  rgb(0 0 0 / 0.25);
            }
            .modal-invoice-header {
                display: flex;
                align-items: start;
                justify-content: space-between;
                padding: 16px;
                border: 1px solid #e5e7eb;
            }
        }
    </style>
</head>

<body class="bg-gray-50 text-gray-800 dark:bg-dark-bg dark:text-gray-200 font-sans antialiased">