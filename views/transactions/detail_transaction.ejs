
    <div class="max-w-5xl mx-auto px-4 py-8">
        <!-- <div class="bg-black text-green-400 p-4 font-mono text-xs">
    DEBUG DATA DETAIL 0:
    <%= JSON.stringify(data.details[0]) %>
</div>  -->
        
        <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4 bg-white p-6 rounded-xl shadow-sm border border-gray-100">
            <div>
                <p class="text-sm text-gray-500 uppercase tracking-wider font-semibold">ID Transaksi</p>
                <h1 class="text-2xl font-bold text-gray-800"><%= data.transaction_no %></h1>
                <p class="text-sm text-gray-400 mt-1">Tanggal: <%= new Date(data.created_at).toLocaleDateString('id-ID') %></p>
            </div>
            <div class="flex items-center gap-3">
                <% 
                    
                    let statusClass = data.status === 'SUCCESS' ? 'bg-green-100 text-green-800 border-green-200' : 'bg-yellow-100 text-yellow-800 border-yellow-200';

                    let dotClass = data.status === 'SUCCESS' ? 'bg-green-500' : 'bg-yellow-500';
                %>
                <span class="<%= statusClass %> text-sm font-medium px-4 py-1.5 rounded-full border flex items-center">
                    <span class="w-2 h-2 me-2 <%= dotClass %> rounded-full"></span>
                    <%= data.status %>
                </span>
                <button data-modal-target="invoiceModal" data-modal-toggle="invoiceModal" class="flex items-center gap-2 px-5 py-2.5 bg-blue-700 text-white rounded-lg hover:bg-blue-900 transition shadow-md">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    Lihat Invoice
                </button>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            <div class="lg:col-span-2 space-y-6">
                
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                    <div class="bg-green-600 px-6 py-3">
                        <h2 class="text-white font-semibold flex items-center gap-2">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0zM6 18a1 1 0 001-1v-2.065a8.935 8.935 0 00-2-.712V17a1 1 0 001 1z"></path></svg>
                            Informasi Paket
                        </h2>
                    </div>
                    <!-- <pre>
    Type of flights: <%= typeof data.details[0].flights_snapshot %>
    Raw data: <%= JSON.stringify(data.details[0].flights_snapshot) %>
</pre> -->
                    <div class="p-6">
                    <% if (data.details && data.details.length > 0) { %>
                        <h3 class="text-xl font-bold text-gray-800 mb-4"><%= data.details[0].product_name %></h3>
                        <div class="grid grid-cols-2 gap-y-4 text-sm">
                            <% if (data.details[0].flights_snapshot && Array.isArray(data.details[0].flights_snapshot)) { %>
                                <% data.details[0].flights_snapshot.forEach(flight => { %>
                                    <div>
                                        <p class="text-gray-400">Maskapai <%= flight.type === 'Departure' ? 'Keberangkatan' : 'Kepulangan' %></p>
                                        <p class="font-medium text-gray-700"><%= flight.airline_name %></p>
                                    </div>
                                <% }) %>
                            <% } %>

                            <div>
                                <p class="text-gray-400">Tanggal Keberangkatan</p>
                                <p class="font-medium text-gray-700">
                                    <%= new Date(data.details[0].departure_date).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %>
                                </p>
                            </div>

                            <div>
                                <p class="text-gray-400">Informasi Hotel</p>
                                <% if (data.details[0].hotels_snapshot && Array.isArray(data.details[0].hotels_snapshot)) { %>
                                    <% data.details[0].hotels_snapshot.forEach(hotel => { %>
                                        <p class="font-medium text-gray-700 italic text-emerald-islamic">
                                            <%= hotel.city %>: <%= hotel.name %> 
                                            (<%= '★'.repeat(hotel.rating) %>) 
                                        </p>
                                    <% }) %>
                                <% } %>
                            </div>
                        </div>
                    <% } %>
                </div>
                </div>

                <div id="accordion-jamaah" data-accordion="collapse" class="bg-white rounded-xl shadow-sm border border-gray-100">
                    <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center">
                        <h2 class="font-bold text-gray-800">Data Jamaah</h2>
                    </div>
                    
                    <h2 id="accordion-heading-1">
                        <div class="flex items-center justify-between w-full p-5 font-medium text-left text-gray-500 border-b border-gray-100 " >
                            <span><%= data.user?.fullname %></span>
                            <!-- <svg data-accordion-icon class="w-3 h-3 rotate-180 shrink-0" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5 5 1 1 5"/>
                            </svg> -->
                        </div>
                    </h2>
                    <div id="body-1" >
                        <div class="p-5 border-b border-gray-100 bg-gray-50/50">
                            <div class="grid grid-cols-2 md:grid-cols-3 gap-4 text-sm">
                                
                                <div>
                                    <p class="text-gray-400 text-xs">No HP</p>
                                    <p class="font-semibold"><%= data.user?.no_wa || "N/A"%></p>
                                </div>
                                <div>
                                    <p class="text-gray-400 text-xs">Email</p>
                                    <p class="font-semibold text-xs"><%= data.user?.email || "N/A"%></p>
                                </div>
                                
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-1">
                <div class="bg-white rounded-xl shadow-md border border-gray-100 sticky top-8">
                    <div class="p-6">
                        <h2 class="text-lg font-bold text-gray-800 mb-6 pb-2 border-b">Ringkasan Pembayaran</h2>
                        <div class="space-y-4 mb-6">
                            <div class="flex justify-between text-sm">
                                <span class="text-gray-500 text-sm">Harga</span>
                                <span class="font-semibold">Rp <%= data.total_price.toLocaleString('id-ID') %></span>
                            </div>
                           <div class="flex justify-between text-sm">
                                <span class="text-gray-500">Metode Pembayaran</span>
                                <span class="font-semibold"><%= data.payment_method %></span>
                            </div>
                            <!-- <div class="flex justify-between text-sm">
                                <span class="text-emerald-islamic font-medium">Diskon Promo</span>
                                <span class="text-emerald-islamic font-semibold">-Rp 1.000.000</span>
                            </div> -->
                        </div>
                        <div class="pt-4 border-t border-dashed border-gray-200">
                           <div class="flex flex-col justify-between items-left mb-6">
                                <span class="text-base font-bold text-gray-800">Total Dibayar</span>
                                <span class="text-xl font-extrabold text-travel-dark">Rp <%= data.total_price.toLocaleString('id-ID') %></span>
                            </div>
                            <button 
                            data-modal-target="approvePaymentModal" data-modal-toggle="approvePaymentModal"
                            class="w-full bg-green-500 text-white font-bold py-3 rounded-xl hover:bg-green-700 transition shadow-lg shadow-green-100">
                                Cek Pembayaran
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="approvePaymentModal" tabindex="-1" aria-hidden="true" class="fixed top-0 left-0 right-0 z-50 hidden w-full p-4 overflow-x-hidden overflow-y-auto md:inset-0 h-[calc(100%-1rem)] max-h-full flex items-center justify-center bg-black bg-opacity-50 backdrop-blur-sm transition-opacity">
    <div class="relative w-full max-w-md max-h-full">
        <div class="relative bg-white rounded-2xl shadow-2xl border border-gray-100">
            <div class="flex items-center justify-between p-4 border-b rounded-t">
                <h3 class="text-xl font-bold text-gray-800">
                    Konfirmasi Pembayaran
                </h3>
                <button type="button" onclick="closeApproveModal()" class="text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center" data-modal-hide="approvePaymentModal">
                    <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
                    </svg>
                </button>
            </div>
            <div class="p-6 text-center">
                <div class="mx-auto mb-4 w-16 h-16 bg-green-100 rounded-full flex items-center justify-center">
                    <i class="ph-bold ph-check-circle text-3xl text-green-600"></i>
                </div>
                <h4 class="text-lg font-semibold text-gray-900 mb-2">Approve Transaksi Ini?</h4>
                <p class="text-sm text-gray-500 mb-6">
                    Pastikan dana sebesar <span class="font-bold text-gray-800 text-base">Rp <%= data.total_price.toLocaleString('id-ID') %></span> telah masuk ke rekening travel sebelum melakukan approval.
                </p>
                
                <div class="bg-gray-50 rounded-xl p-4 mb-6 text-left border border-gray-200">
                    <div class="flex justify-between mb-2">
                        <span class="text-xs text-gray-400">Metode</span>
                        <span class="text-xs font-bold text-gray-700 uppercase"><%= data.payment_method %></span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-xs text-gray-400">User</span>
                        <span class="text-xs font-bold text-gray-700"><%= data.user?.fullname %></span>
                    </div>
                    <div class="flex justify-center mt-4">
                    <div class="flex flex-col items-center justify-center border-2 border-dashed 
                        border-gray-300 dark:border-gray-600 rounded-xl p-6 text-center">

                        <% if (data.evidence_url) { %>
                            <p class="text-xs text-gray-400 mb-2 font-bold uppercase">Bukti Pembayaran:</p>
                            <img class="max-h-64 rounded-lg shadow-md border" 
                                src="/assets/img/transactions/<%= data.evidence_url %>" 
                                alt="Bukti Transfer"
                                > <a href="/assets/img/transactions/<%= data.evidence_url %>" target="_blank" class="mt-3 text-xs text-blue-500 underline">
                                Lihat Ukuran Penuh
                            </a>
                        <% } else { %>
                            <i class="ph ph-image text-3xl text-gray-400 mb-2"></i>
                            <p class="text-sm text-gray-500 dark:text-gray-400">
                                Jama'ah belum mengunggah bukti pembayaran. Silahkan hubungi jama'ah untuk mendapatkan bukti transfer.
                            </p>
                        <% } %>

                    </div>
                </div>
                </div>

                <div class="flex gap-3">
                    <button type="button" data-modal-hide="approvePaymentModal" class="w-full text-gray-500 bg-white border border-gray-300 hover:bg-gray-100 font-medium rounded-xl text-sm px-5 py-3 transition-all">
                        Batal
                    </button>
                    <button type="button" 
                    onclick="window.confirmApproveBtn(<%= data.id %>)"
                    id="confirmApproveBtn" class="w-full text-white bg-green-600 hover:bg-green-700 shadow-lg shadow-green-200 font-bold rounded-xl text-sm px-5 py-3 transition-all flex items-center justify-center gap-2">
                        <i class="ph-bold ph-check"></i>
                        Ya, Approve
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

    <div id="invoiceModal" tabindex="-1" aria-hidden="true" class="fixed top-0 left-0 right-0 z-50 hidden w-full p-4 overflow-x-hidden overflow-y-auto md:inset-0 h-[calc(100%-1rem)] max-h-full backdrop-blur-sm transition-opacity">
        <div class="relative w-full max-w-2xl max-h-full">
            <div class="relative bg-white rounded-2xl shadow-2xl">
                <div class="flex items-start justify-between p-4 border-b rounded-t">
                    <h3 class="text-xl font-semibold text-gray-900">E-Invoice</h3>
                    <button type="button" class="text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm w-8 h-8 ml-auto inline-flex justify-center items-center" data-modal-hide="invoiceModal">
                        <svg class="w-3 h-3" fill="none" viewBox="0 0 14 14"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/></svg>
                    </button>
                </div>
                <div class="p-8" id="invoicePrintArea">
                    <div class="flex justify-between mb-8">
                        <div>
                            <div class="mb-8">
                                    <img src="../assets/img/logo/pengenumroh.png" alt="Logo" class="h-12 w-auto">
                            </div>
                                <!-- <h4 class="text-2xl font-bold text-travel-dark">
                                    
                                    <%= data.details?.[0]?.travel_snapshot?.fullname || "TRAVEL" %>
                                </h4>
                                 -->
                        </div>
                        <div class="text-right">
                            <h5 class="font-bold text-lg">INVOICE</h5>
                             <p class="text-sm text-gray-600"><%= data.transaction_no %></p>
                            <p class="text-sm text-gray-600"><% 
                                const date = new Date(data.created_at);
                                const year = date.getFullYear();
                                const month = String(date.getMonth() + 1).padStart(2, '0');
                                const invId = String(data.id).padStart(3, '0');
                                %>#INV/<%= year %>/<%= month %>/<%= invId %>
                            </p> 
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-8 mb-8 text-sm">
                        <div>
                            <p class="text-gray-400 mb-1">Ditagihkan Kepada:</p>
                            <p class="font-bold text-gray-800"><%= data.user?.fullname %></p>
                            <p class="text-gray-600"><%= data.user?.email || "No email"%></p>
                        </div>
                        <div class="text-right">
                            <p class="text-gray-400 mb-1">Metode Pembayaran:</p>
                            <p class="font-bold text-gray-800">Bank Central Asia (BCA)</p>
                            <p class="text-gray-600">VA: 12345678</p>
                        </div>
                    </div>

                    <table class="w-full text-sm text-left border-collapse mb-8">
                        <thead>
                            <tr class=" border-b">
                                <th class="py-3 px-2 font-bold">Deskripsi Layanan</th>
                                <th class="py-3 px-2 text-center font-bold">Qty</th>
                                <th class="py-3 px-2 text-right font-bold">Harga</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            <% if (data.details && data.details.length > 0) { %>
                                <% data.details.forEach(detail => { %>
                                    <tr>
                                        <td class="py-4 px-2">
                                            <p class="font-medium text-gray-800"><%= detail.product_name %></p>
                                            <p class="text-xs text-gray-500 italic"><%= new Date(detail.departure_date).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %></p>
                                        </td>
                                        <td class="py-4 px-2 text-center text-gray-600">(<%= detail.room_type %>)</td>
                                        <td class="py-4 px-2 text-right font-medium">Rp <%= detail.price.toLocaleString('id-ID') %></td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>

                    <div class="flex justify-end">
                        <div class="w-64 space-y-2">
                            <% data.details.forEach((item) => { %>
                            <div class="flex justify-between text-sm">
                                <span class="text-gray-500"><%= item.product_name %></span>
                                <span class="font-medium">Rp <%= item.price.toLocaleString('id-ID') %></span>
                            </div>
                            <% }) %>
                            <!-- <div class="flex justify-between text-sm">
                                <span class="text-gray-500">Diskon</span>
                                <span class="text-emerald-islamic">-Rp 1.000.000</span>
                            </div> -->
                            <div class="flex flex-col align-left justify-between border-t pt-2 mt-2">
                                <span class="font-bold text-gray-800 uppercase">Total Akhir</span>
                                <span class="font-bold text-xl text-travel-dark">Rp. <%= data.total_price.toLocaleString('id-ID') %></span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="flex items-center justify-end p-6 space-x-2 border-t border-gray-200 rounded-b">
                    <button data-modal-hide="invoiceModal" type="button" class="text-gray-500 bg-white hover:bg-gray-100 rounded-lg border border-gray-200 text-sm font-medium px-5 py-2.5">Tutup</button>
                    <button type="button" id="btnPrint"
                    onclick="window.print()"
                    class="text-white bg-green-600 hover:bg-green-700 font-medium rounded-lg text-sm px-5 py-2.5 flex items-center gap-2">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M5 4a2 2 0 012-2h6a2 2 0 012 2v14l-5-2.5L5 18V4z"></path></svg>
                        Cetak PDF
                    </button>
                </div>
            </div>
        </div>
    </div>
