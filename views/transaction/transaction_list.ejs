  <div id="transactionModal" class="fixed inset-0 z-[80] hidden" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm transition-opacity" id="transactionModalBackdrop"></div>
    <div class="fixed inset-0 z-10 overflow-y-auto">
      <div class="flex min-h-full items-center justify-center p-4">
        <div
          class="relative transform overflow-hidden rounded-2xl bg-white dark:bg-dark-card text-left shadow-xl transition-all sm:w-full sm:max-w-lg">
          <div class="px-6 py-4 border-b border-gray-100 dark:border-dark-border flex justify-between items-center">
            <h3 class="text-lg font-bold text-gray-900 dark:text-white" id="modalTitle">Edit Transaksi</h3>
            <button type="button" onclick="closeTransactionModal()"
              class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
              <i class="ph ph-x text-xl"></i>
            </button>
          </div>

          <form id="transactionForm" class="p-6 space-y-4">
            <input type="hidden" id="hidden_id">

            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">No. Transaksi</label>
              <input type="text" id="transaction_no" readonly
                class="w-full px-4 py-2 rounded-xl bg-gray-100 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 text-gray-500 dark:text-gray-400">
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Nama Jama'ah</label>
              <input type="text" id="name"
                class="w-full px-4 py-2 rounded-xl bg-gray-50 dark:bg-slate-800 border border-gray-200 dark:border-slate-700 focus:border-primary-500 outline-none transition-all dark:text-white"
                required>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Jumlah (Rp)</label>
              <input type="number" id="amount"
                class="w-full px-4 py-2 rounded-xl bg-gray-50 dark:bg-slate-800 border border-gray-200 dark:border-slate-700 focus:border-primary-500 outline-none transition-all dark:text-white"
                required>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Metode Pembayaran</label>
                <select id="payment_method"
                  class="w-full px-4 py-2 rounded-xl bg-gray-50 dark:bg-slate-800 border border-gray-200 dark:border-slate-700 focus:border-primary-500 outline-none transition-all dark:text-white">
                  <option value="">-- Pilih --</option>
                  <option value="CASH">CASH</option>
                  <option value="TRANSFER">TRANSFER</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Status</label>
                <select id="status"
                  class="w-full px-4 py-2 rounded-xl bg-gray-50 dark:bg-slate-800 border border-gray-200 dark:border-slate-700 focus:border-primary-500 outline-none transition-all dark:text-white">
                  <option value="PENDING">PENDING</option>
                  <option value="SUCCESS">SUCCESS</option>
                  <option value="UNPAID">UNPAID</option>
                  <option value="FAILED">FAILED</option>
                </select>
              </div>
            </div>
          </form>

          <div
            class="bg-gray-50 dark:bg-slate-800/50 px-6 py-4 flex justify-end gap-3 border-t border-gray-100 dark:border-dark-border">
            <button onclick="closeTransactionModal()"
              class="px-5 py-2 text-sm font-semibold text-gray-700 dark:text-gray-300">Batal</button>
            <button id="submitTransactionBtn"
              class="bg-primary-600 hover:bg-primary-700 text-white px-5 py-2 rounded-xl text-sm font-semibold transition-all shadow-lg shadow-primary-500/30">
              Simpan Perubahan
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>