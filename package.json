{
  "scripts": {
    "dev": "node app.js",
    "start": "NODE_ENV=production node app.js",
    "css:build": "tailwindcss -i ./src/input.css -o ./public/stylesheets/output.css",
    "css:watch": "tailwindcss -i ./src/input.css -o ./public/stylesheets/output.css --watch",
    "dev:all": "concurrently \"npm run css:watch\" \"npm run dev\""
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "multer": "^2.1.1",
    "mysql2": "^3.19.1",
    "pug": "^3.0.3",
    "sequelize": "^6.37.8",
    "simple-datatables": "^10.2.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "flowbite": "^4.0.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19"
  }
}
